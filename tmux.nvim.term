" nvim wrapper to allow leader key

set cmdheight=0
set laststatus=0
set mouse=
set splitright

autocmd TermOpen * startinsert
if has('nvim')
  tnoremap ,E <C-\><C-n>
  tnoremap ,l ls -l<cr>
  tnoremap <C-v><Esc> <Esc>
  " tnoremap <Esc> <C-\><C-n>
  tnoremap <M-[> <Esc>
endif

nnoremap ,t :vsplit term://bash<cr>
nnoremap ,w :w<cr>
nnoremap ,st :source ~/repo/dotfiles/tmux.nvim.term<cr>

term
