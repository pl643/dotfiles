" nvim wrapper to allow leader key

set cmdheight=0
set laststatus=0
set mouse=
set splitright

autocmd TermOpen * startinsert

tnoremap ,E <C-\><C-n>
tnoremap ,l ls -l<cr>
tnoremap <C-v><Esc> <Esc>
" tnoremap <Esc> <C-\><C-n>
tnoremap <M-[> <Esc>

nnoremap ,st <C-\><C-n>:source ~/repo/dotfiles/tmux.nvim.term<cr>

nnoremap ,et :e ~/repo/dotfiles/tmux.nvim.term<cr>
nnoremap ,t :vsplit term://bash<cr>
nnoremap ,w :w<cr>
nnoremap ,3 :buffer #<cr>
nnoremap q :q<cr>
